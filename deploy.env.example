# Example environment for Docker Compose / Dokploy (copy to .env or paste into host UI).
# Do not commit real secrets.

# --- API ---
MONGODB_URI=mongodb://mongo:27017/ijcds-cms
JWT_SECRET=use-a-long-random-string
JWT_REFRESH_SECRET=use-a-different-long-random-string

# Exact browser origins (no trailing slash). Comma-separate if you have multiple.
CLIENT_URL=https://your-journal.vercel.app
ADMIN_URL=https://your-admin.vercel.app
CORS_EXTRA_ORIGINS=
# Optional: allow all https://*.vercel.app (preview deploys)
ALLOW_VERCEL_PREVIEW_CORS=false
# Optional: same-site-only refresh cookies (only if admin and API are same-site)
REFRESH_COOKIE_STRICT=false
# If API NODE_ENV is not production, enable cross-site cookie attributes explicitly:
# CROSS_SITE_REFRESH_COOKIES=true

# --- Frontends (baked into Vite build at docker build time) ---
# Public client: MUST include /api/v1/public
CLIENT_VITE_API_URL=https://your-api.example.com/api/v1/public
# Admin: MUST be .../api/v1 with NO /public
ADMIN_VITE_API_URL=https://your-api.example.com/api/v1

# Optional admin GA
# VITE_GA_DASHBOARD_URL=
